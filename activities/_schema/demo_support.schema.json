{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderlens.local/schemas/demo_support.schema.json",
  "title": "WonderLens demo_support.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": ["activity_id", "version", "entity_compatibility", "demo_support"],
  "properties": {
    "activity_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "entity_compatibility": {
      "type": "string",
      "enum": ["source_bound", "agnostic", "unsupported"]
    },
    "parameterization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "decision_source",
        "integrity_status",
        "confidence",
        "evidence",
        "reviewer_action",
        "fallback_behavior"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "fixed",
            "entity_theme",
            "entity_target",
            "property_target",
            "initial_sound_from_entity",
            "word_from_entity",
            "asset_catalog_target",
            "unsupported_until_parameterized"
          ]
        },
        "decision_source": {
          "type": "string",
          "minLength": 1
        },
        "integrity_status": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reviewer_action": {
          "type": "string",
          "minLength": 1
        },
        "validity": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "production_supported": {
              "type": "boolean"
            },
            "requires": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "allowed_entity_classes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "invalid_when": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "source_fields": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "derived_runtime_fields": {
          "type": "object"
        },
        "authored_constants": {
          "type": "object"
        },
        "fallback_behavior": {
          "type": "string",
          "minLength": 1
        },
        "stale_text_risk": {
          "type": "string",
          "minLength": 1
        },
        "consumer_notes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "demo_support": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "ui_template",
        "support_level",
        "entity_bindings",
        "requires",
        "unsupported_reasons",
        "degraded_reasons",
        "consumer_notes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["supported", "degraded", "unsupported"]
        },
        "ui_template": {
          "type": "string",
          "enum": ["cat1_dialogue", "cat5_collection", "cat5_judgment", "none"]
        },
        "support_level": {
          "type": "string",
          "minLength": 1
        },
        "entity_bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["entity_id", "display_label", "source_entity_exemplar", "default"],
            "properties": {
              "entity_id": {
                "type": "string",
                "minLength": 1
              },
              "display_label": {
                "type": "string",
                "minLength": 1
              },
              "source_entity_exemplar": {
                "type": "string",
                "minLength": 1
              },
              "default": {
                "type": "boolean"
              }
            }
          }
        },
        "requires": {
          "type": "object",
          "additionalProperties": false,
          "required": ["generated_assets", "real_camera", "runtime_judgment", "device_round_screen"],
          "properties": {
            "generated_assets": {
              "type": "boolean"
            },
            "real_camera": {
              "type": "boolean"
            },
            "runtime_judgment": {
              "type": "boolean"
            },
            "device_round_screen": {
              "type": "boolean"
            }
          }
        },
        "unsupported_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "degraded_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "consumer_notes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["entity_compatibility"],
        "properties": {
          "entity_compatibility": {
            "const": "agnostic"
          }
        }
      },
      "then": {
        "required": ["parameterization"],
        "properties": {
          "parameterization": {
            "required": ["mode"],
            "properties": {
              "mode": {
                "enum": [
                  "entity_theme",
                  "entity_target",
                  "property_target",
                  "initial_sound_from_entity",
                  "word_from_entity",
                  "asset_catalog_target"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["entity_compatibility"],
        "properties": {
          "entity_compatibility": {
            "const": "unsupported"
          }
        }
      },
      "then": {
        "required": ["parameterization"],
        "properties": {
          "parameterization": {
            "required": ["mode"],
            "properties": {
              "mode": {
                "const": "unsupported_until_parameterized"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["demo_support"],
        "properties": {
          "demo_support": {
            "required": ["status"],
            "properties": {
              "status": {
                "enum": ["supported", "degraded"]
              }
            }
          }
        }
      },
      "then": {
        "required": ["parameterization"],
        "properties": {
          "parameterization": {
            "properties": {
              "mode": {
                "enum": [
                  "fixed",
                  "entity_theme",
                  "entity_target",
                  "property_target",
                  "initial_sound_from_entity",
                  "word_from_entity",
                  "asset_catalog_target"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["demo_support"],
        "properties": {
          "demo_support": {
            "required": ["status"],
            "properties": {
              "status": {
                "const": "unsupported"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "parameterization": {
            "properties": {
              "mode": {
                "enum": ["fixed", "entity_theme", "unsupported_until_parameterized"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["parameterization"],
        "properties": {
          "parameterization": {
            "required": ["mode"],
            "properties": {
              "mode": {
                "enum": [
                  "entity_target",
                  "property_target",
                  "initial_sound_from_entity",
                  "word_from_entity",
                  "asset_catalog_target"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "parameterization": {
            "required": ["validity", "source_fields", "derived_runtime_fields"],
            "properties": {
              "validity": {
                "required": ["requires"],
                "properties": {
                  "requires": {
                    "minItems": 1
                  }
                }
              },
              "source_fields": {
                "minProperties": 1
              },
              "derived_runtime_fields": {
                "minProperties": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["parameterization"],
        "properties": {
          "parameterization": {
            "required": ["mode"],
            "properties": {
              "mode": {
                "enum": ["fixed", "entity_theme"]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "parameterization": {
            "required": ["authored_constants"],
            "properties": {
              "authored_constants": {
                "minProperties": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["demo_support"],
        "properties": {
          "demo_support": {
            "required": ["status"],
            "properties": {
              "status": {
                "const": "supported"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "demo_support": {
            "properties": {
              "ui_template": {
                "enum": ["cat1_dialogue", "cat5_collection"]
              },
              "entity_bindings": {
                "minItems": 1
              },
              "unsupported_reasons": {
                "maxItems": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["demo_support"],
        "properties": {
          "demo_support": {
            "required": ["status"],
            "properties": {
              "status": {
                "const": "degraded"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "demo_support": {
            "properties": {
              "ui_template": {
                "enum": ["cat1_dialogue", "cat5_collection", "cat5_judgment"]
              },
              "entity_bindings": {
                "minItems": 1
              },
              "degraded_reasons": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["demo_support"],
        "properties": {
          "demo_support": {
            "required": ["status"],
            "properties": {
              "status": {
                "const": "unsupported"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "demo_support": {
            "properties": {
              "ui_template": {
                "const": "none"
              },
              "unsupported_reasons": {
                "minItems": 1
              }
            }
          }
        }
      }
    }
  ]
}
