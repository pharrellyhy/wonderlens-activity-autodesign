{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderlens.local/schemas/asset_manifest.schema.json",
  "title": "WonderLens asset_manifest.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": ["activity_id", "entity_id", "version", "style_id", "palette", "screen_targets", "assets"],
  "properties": {
    "activity_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "entity_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "style_id": {
      "type": "string",
      "enum": ["wonderlens_device_mint_soft_3d"]
    },
    "palette": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "required": ["shell", "screen", "primary_accent"],
      "properties": {
        "shell": {
          "type": "string",
          "minLength": 1
        },
        "screen": {
          "type": "string",
          "minLength": 1
        },
        "primary_accent": {
          "type": "string",
          "minLength": 1
        },
        "secondary_accent": {
          "type": "string"
        },
        "shadow": {
          "type": "string"
        }
      }
    },
    "screen_targets": {
      "type": "object",
      "required": ["round_device_screen"],
      "additionalProperties": {
        "$ref": "#/$defs/screen_target"
      },
      "properties": {
        "round_device_screen": {
          "allOf": [
            {
              "$ref": "#/$defs/screen_target"
            },
            {
              "type": "object",
              "required": ["aspect_ratio", "crop_shape", "master_size", "safe_area"],
              "properties": {
                "aspect_ratio": {
                  "const": "1:1"
                },
                "crop_shape": {
                  "const": "circle"
                },
                "safe_area": {
                  "type": "string",
                  "pattern": ".*(percent.*circle|circle.*percent).*"
                }
              }
            }
          ]
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/asset"
      }
    }
  },
  "$defs": {
    "screen_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aspect_ratio", "master_size"],
      "properties": {
        "aspect_ratio": {
          "type": "string",
          "minLength": 1
        },
        "crop_shape": {
          "type": "string",
          "enum": ["circle", "rectangle", "rounded_rectangle"]
        },
        "master_size": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "safe_area": {
          "type": "string"
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "label", "requiredness", "accuracy_mode", "source_strategy", "transformation_policy", "variants", "fallback_behavior"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "role": {
          "type": "string",
          "enum": [
            "entity",
            "activity_preview",
            "collection_correct",
            "collection_distractor",
            "badge",
            "story_scene",
            "ui_overlay"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "entity_name": {
          "type": "string",
          "minLength": 1
        },
        "collection_catalog_id": {
          "type": "string",
          "minLength": 1
        },
        "requiredness": {
          "type": "string",
          "enum": ["required", "optional", "fallback"]
        },
        "accuracy_mode": {
          "type": "string",
          "enum": ["illustrative", "reference_bound"]
        },
        "source_strategy": {
          "type": "string",
          "enum": [
            "generated_illustrative",
            "curated_original",
            "redraw_from_verified_data",
            "licensed_reference",
            "approved_internal_reference"
          ]
        },
        "transformation_policy": {
          "type": "string",
          "enum": [
            "generate_new",
            "crop_resize_only",
            "simplified_redraw",
            "style_preserving_redraw",
            "no_derivative_generation"
          ]
        },
        "prompt_en": {
          "type": "string"
        },
        "reference_policy": {
          "$ref": "#/$defs/reference_policy"
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "variants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/variant"
          }
        },
        "fallback_behavior": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "role": {
                "enum": ["entity", "collection_correct", "collection_distractor", "ui_overlay"]
              }
            },
            "required": ["role"]
          },
          "then": {
            "required": ["entity_name"]
          }
        },
        {
          "if": {
            "properties": {
              "accuracy_mode": {
                "const": "reference_bound"
              }
            }
          },
          "then": {
            "required": ["source_strategy", "transformation_policy", "reference_policy", "sources"],
            "properties": {
              "source_strategy": {
                "enum": [
                  "curated_original",
                  "redraw_from_verified_data",
                  "licensed_reference",
                  "approved_internal_reference"
                ]
              },
              "transformation_policy": {
                "enum": [
                  "crop_resize_only",
                  "simplified_redraw",
                  "style_preserving_redraw",
                  "no_derivative_generation"
                ]
              },
              "sources": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "accuracy_mode": {
                "const": "illustrative"
              },
              "requiredness": {
                "enum": ["required", "optional"]
              }
            }
          },
          "then": {
            "required": ["source_strategy", "transformation_policy", "prompt_en"],
            "properties": {
              "source_strategy": {
                "const": "generated_illustrative"
              },
              "transformation_policy": {
                "const": "generate_new"
              }
            }
          }
        }
      ]
    },
    "reference_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_required", "allowed_sources", "verification_required", "verification_notes"],
      "properties": {
        "source_required": {
          "const": true
        },
        "allowed_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "licensed_asset",
              "public_domain_reference",
              "approved_internal_reference",
              "verified_source_url"
            ]
          }
        },
        "verification_required": {
          "const": true
        },
        "verification_notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "uri", "license"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": [
            "licensed_asset",
            "public_domain_reference",
            "approved_internal_reference",
            "verified_source_url"
          ]
        }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "size"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "string",
          "pattern": "^[0-9]+x[0-9]+$"
        },
        "path": {
          "type": ["string", "null"]
        },
        "mime_type": {
          "type": ["string", "null"]
        },
        "byte_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
