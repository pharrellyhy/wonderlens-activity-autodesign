{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderlens.local/schemas/activity_display_contract_v1.schema.json",
  "title": "WonderLens activity_display_contract_v1.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": ["activity_id", "version", "contract", "display_assets", "frames"],
  "properties": {
    "activity_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "contract": {
      "type": "string",
      "const": "activity_display_contract_v1"
    },
    "display_assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/display_asset"
      }
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/frame"
      }
    }
  },
  "$defs": {
    "display_asset": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "item"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["metadata"],
            "properties": {
              "metadata": {
                "required": ["entity_name"],
                "properties": {
                  "entity_name": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      ],
      "required": ["display_asset_id", "kind"],
      "properties": {
        "display_asset_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "kind": {
          "type": "string",
          "enum": ["image", "option", "cue", "number", "category", "word", "scene", "item", "group"]
        },
        "asset_manifest_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_id",
        "step_ref",
        "layout_id",
        "display_asset_id",
        "control_mode",
        "input_affordance",
        "verification_policy",
        "effect_profile"
      ],
      "properties": {
        "frame_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "step_ref": {
          "type": "string",
          "minLength": 1
        },
        "layout_id": {
          "type": "string",
          "enum": [
            "single_image",
            "two_image_options",
            "two_direction_options",
            "two_number_options",
            "multi_option_carousel"
          ]
        },
        "display_asset_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "control_mode": {
          "type": "string",
          "enum": [
            "voice_only",
            "binary_choice",
            "carousel_choice",
            "number_choice",
            "step_confirm",
            "camera_capture",
            "replay_only",
            "reveal_control",
            "sort_pick_place",
            "self_report"
          ]
        },
        "input_affordance": {
          "$ref": "#/$defs/input_affordance"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/option"
          }
        },
        "verification_policy": {
          "$ref": "#/$defs/verification_policy"
        },
        "effect_profile": {
          "$ref": "#/$defs/effect_profile"
        }
      }
    },
    "input_affordance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["select", "confirm"],
      "properties": {
        "select": {
          "type": "string",
          "enum": ["none", "wheel"]
        },
        "confirm": {
          "type": "string",
          "enum": ["voice", "press", "auto"]
        }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["option_id", "label"],
      "properties": {
        "option_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "display_asset_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "value": {},
        "is_correct": {
          "type": "boolean"
        }
      }
    },
    "verification_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "required", "target", "evidence"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "choice_match",
            "number_match",
            "category_match",
            "alias_match",
            "echo_match",
            "photo_object_initial_sound",
            "semantic_llm_judge",
            "self_report",
            "accept_any_participation"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "target": {
          "type": "object"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "effect_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sound_effects", "lighting_effects", "haptic_feedback"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "sound_effects": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        },
        "lighting_effects": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        },
        "haptic_feedback": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        }
      }
    }
  }
}
